# Database
DATABASE_URL=postgresql://shayfinance:shayfinance_dev@localhost:5432/shayfinance

# Encryption key for bank credentials (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=

# App password (bcrypt hash — generate with: node -e "require('bcrypt').hash('yourpassword', 12).then(console.log)")
APP_PASSWORD=

# Path to Chromium/Chrome executable (required for puppeteer-core)
# macOS: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux: /usr/bin/chromium-browser
# Docker: /usr/bin/chromium (set automatically in Dockerfile)
CHROMIUM_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
